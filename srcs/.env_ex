# The domain name. It must point to your local IP, which should be
# set in /etc/hosts with the line: 127.0.0.1 login.42.fr
DOMAIN_NAME=login.42.fr

# The database name and the normal database user name.
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user

# The hostname WordPress uses to reach the database. On the Docker network the
# hostname is the same as the service name, which is mariadb.
MYSQL_HOST=mariadb

# The WordPress admin account. Only the name and email are here
WP_ADMIN_USER=login_goat
WP_ADMIN_EMAIL=login_goat@login.42.fr

# The second, non-admin WordPress account. Name and email only.
WP_USER=guest
WP_USER_EMAIL=guest@login.42.fr

# Site information used when WordPress is installed.
WP_TITLE=Inception
WP_URL=https://login.42.fr
